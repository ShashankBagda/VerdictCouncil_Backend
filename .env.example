# ------------------------------------------------------------------- #
# Required
# ------------------------------------------------------------------- #
OPENAI_API_KEY=sk-proj-...
SOLACE_BROKER_URL=tcp://localhost:55555
SOLACE_BROKER_VPN=verdictcouncil
SOLACE_BROKER_USERNAME=vc-agent
SOLACE_BROKER_PASSWORD=vc-agent-password
DATABASE_URL=postgresql://vc_dev:vc_dev_password@localhost:5432/verdictcouncil
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=change-me-in-production
COOKIE_SECURE=false

# Comma-separated list of origins allowed by the CORS middleware.
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# ------------------------------------------------------------------- #
# Application
# ------------------------------------------------------------------- #
NAMESPACE=verdictcouncil
FASTAPI_HOST=0.0.0.0
# Note: Procfile.dev launches uvicorn on :8001 (hard-coded in the Procfile).
# FASTAPI_PORT only applies if you start the API without honcho, e.g.
# `python -m uvicorn src.api.app:app --port $FASTAPI_PORT`.
FASTAPI_PORT=8001
LOG_LEVEL=DEBUG
PRECEDENT_CACHE_TTL_SECONDS=86400

# ------------------------------------------------------------------- #
# PAIR precedent API + circuit breaker
# ------------------------------------------------------------------- #
PAIR_API_URL=https://search.pair.gov.sg/api/v1/search
PAIR_CIRCUIT_BREAKER_THRESHOLD=3
PAIR_CIRCUIT_BREAKER_TIMEOUT=60

# ------------------------------------------------------------------- #
# OpenAI models
# ------------------------------------------------------------------- #
OPENAI_VECTOR_STORE_ID=vs_...
OPENAI_MODEL_LIGHTWEIGHT=gpt-5.4-nano
OPENAI_MODEL_EFFICIENT_REASONING=gpt-5-mini
OPENAI_MODEL_STRONG_REASONING=gpt-5
OPENAI_MODEL_FRONTIER_REASONING=gpt-5.4

# ------------------------------------------------------------------- #
# Password reset
# ------------------------------------------------------------------- #
# How long a reset token stays valid before the user must request a new one.
RESET_TOKEN_TTL_MINUTES=30
# Front-end URL the reset email links to. The token is appended as ?token=...
PASSWORD_RESET_BASE_URL=http://localhost:5173/reset-password

# ------------------------------------------------------------------- #
# SMTP (password reset mailer)
# ------------------------------------------------------------------- #
# Leave SMTP_HOST empty to skip real email delivery — the reset link will be
# logged at WARNING level server-side for manual hand-off in dev.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=no-reply@verdictcouncil.local

# ------------------------------------------------------------------- #
# Local persistence (knowledge base + admin runtime data)
# ------------------------------------------------------------------- #
KNOWLEDGE_BASE_STORAGE_DIR=data/knowledge_base
ADMIN_STORAGE_DIR=data/admin
